# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: Set explicit browser binary path if auto-detection fails
# Linux example: /usr/bin/chromium
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_BIN=

# Optional: Set explicit chromedriver path if needed
# Linux example: /usr/bin/chromedriver
# Windows example: C:\tools\chromedriver.exe
CHROMEDRIVER_PATH=
